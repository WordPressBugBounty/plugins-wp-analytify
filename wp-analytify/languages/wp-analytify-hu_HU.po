#: classes/analytify-settings/fields.php:242
msgid "AJAX Errors"
msgstr "AJAX hibák"

#: classes/analytify-settings/fields.php:243
msgid "Track all AJAX errors."
msgstr "Kövesse nyomon az összes AJAX hibát."

#: classes/analytify-settings/fields.php:248
msgid "Setup Cross-domain Tracking"
msgstr "Állítsa be a keresztdomain nyomkövetést"

#: classes/analytify-settings/fields.php:250
#. translators: %1$s is the code tag, %2$s is the opening link tag, %3$s is the closing link tag.
