#: inc/analytify-optin-form.php:233
msgid "Admin tab section is to manage the Analytics panels under EDIT screen of post/pages in wp-admin."
msgstr "La sección de la pestaña de Administrador es para gestionar los paneles de Análisis en la pantalla de EDITAR de publicaciones/páginas en wp-admin."

#: inc/analytify-optin-form.php:237
msgid "Disable Analytics under posts/pages."
msgstr "Desactivar Análisis en publicaciones/páginas."

#: inc/analytify-optin-form.php:238
