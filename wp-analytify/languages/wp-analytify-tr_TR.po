#: inc/analytify-optin-form.php:52
msgid "Your Website Overview"
msgstr "Web Sitenizin Genel Görünümü"

#: inc/analytify-optin-form.php:53
msgid ""
"Your Site URL, WordPress & PHP version, plugins & themes. This data lets us "
"make sure this plugin always stays compatible with the most popular plugins "
"and themes."
msgstr ""
"Site URL'niz, WordPress & PHP versiyonu, eklentiler & temalar. Bu veriler, "
"bu eklentinin her zaman en popüler eklentiler ve temalarla uyumlu kalmasını "
"sağlamamıza yardımcı olur."

#: inc/analytify-optin-form.php:55
msgid "Your Profile Overview"
msgstr "Profilinizin Genel Görünümü"

#: inc/analytify-optin-form.php:56
msgid "Your name and email address."
msgstr "Adınız ve e-posta adresiniz."

#: inc/analytify-optin-form.php:58
